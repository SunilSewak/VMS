{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting (relaxed for Phase 5A stabilization) */
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": false,

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "react-router-dom": ["src/lib/shims/react-router-dom.tsx"],
      "@tanstack/react-query": ["src/lib/shims/react-query.tsx"],
      "react-hook-form": ["src/lib/shims/react-hook-form.tsx"],
      "zod": ["src/lib/shims/zod.ts"]
    },
    
    /* Explicitly exclude node_modules from type checking */
    "types": []
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
